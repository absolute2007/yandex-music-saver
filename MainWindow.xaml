<Window
    x:Class="YandexMusicSaver.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:YandexMusicSaver"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Yandex Music Saver">

    <Grid Background="#1C1C1C">
        <Border
            x:Name="BackgroundCover"
            HorizontalAlignment="Center"
            VerticalAlignment="Stretch"
            Margin="0,48"
            CornerRadius="18"
            Opacity="0" />
        <Border Background="#1C1C1C" Opacity="0.76" />
        
        <Grid Padding="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Yandex Music Saver" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,24" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16" MaxWidth="700" HorizontalAlignment="Center">
                
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="16">
                        <ItemsControl x:Name="UrlsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Text="{Binding Url, Mode=TwoWay}" PlaceholderText="https://music.yandex.ru/..." VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Margin="8,0,0,0" FontFamily="Segoe Fluent Icons" Content="&#xE106;" Click="RemoveUrlButton_Click" Tag="{Binding}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                        <Button Content="Добавить ссылку" HorizontalAlignment="Left" Click="AddUrlButton_Click" />
                    </StackPanel>
                </Border>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Параметры загрузки" Style="{StaticResource SubtitleTextBlockStyle}"/>

                        <Grid ColumnSpacing="16" RowSpacing="16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Папка сохранения" VerticalAlignment="Center" Width="150" />
                            <Grid Grid.Row="0" Grid.Column="1" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="FolderTextBox" IsReadOnly="True" Grid.Column="0" />
                                <Button x:Name="SelectFolderButton" Click="SelectFolderButton_Click" Grid.Column="1">Обзор...</Button>
                            </Grid>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Cookies браузера" VerticalAlignment="Center" Width="150" ToolTipService.ToolTip="Используются для авторизации и доступа к трекам с ограничениями." />
                            <ComboBox x:Name="BrowserComboBox" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="Нет" Tag="None" IsSelected="True" />
                                <ComboBoxItem Content="Chrome" Tag="Chrome" />
                                <ComboBoxItem Content="Edge" Tag="Edge" />
                                <ComboBoxItem Content="Firefox" Tag="Firefox" />
                                <ComboBoxItem Content="Opera" Tag="Opera" />
                                <ComboBoxItem Content="Brave" Tag="Brave" />
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="16">
                        <Button x:Name="DownloadButton" Content="Начать загрузку" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Stretch" Height="44" FontSize="16" Click="DownloadButton_Click"/>

                        <StackPanel x:Name="ProgressContainer" Spacing="8" Visibility="Collapsed">
                            <TextBlock x:Name="TrackTitleTextBlock" Text="Подготовка загрузки..." Style="{StaticResource BodyStrongTextBlockStyle}" TextTrimming="CharacterEllipsis"/>
                            <ProgressBar x:Name="DownloadProgressBar" Minimum="0" Maximum="100" Value="0" HorizontalAlignment="Stretch" />
                            <Grid>
                                <TextBlock x:Name="StatusTextBlock" Text="0%" HorizontalAlignment="Left" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock x:Name="DetailsTextBlock" Text="-- МБ/с • осталось: --:--" HorizontalAlignment="Right" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
    </Grid>
</Window>
